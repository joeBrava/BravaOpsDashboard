# Brava Ops Dashboard — environment configuration.
# Copy to `.env.local` and fill in. The app runs on FIXTURES with auth DISABLED
# until these are set, so local development needs nothing here to boot.

# --- Data source ---------------------------------------------------------
# "live" reads real (READ-ONLY) data from HubSpot + Teamwork. Any other value,
# or missing tokens, keeps the app on built-in fixtures.
DATA_SOURCE=fixture

# HubSpot private-app token (read-only scopes).
# 1Password: op://APIs/HubSpot Service Key/credential
HUBSPOT_API_TOKEN=

# Teamwork API token.  1Password: op://APIs/TeamWork API/credential
TEAMWORK_API_TOKEN=
TEAMWORK_DOMAIN=bravabrands.teamwork.com

# --- Auth (Auth.js / Google SSO, domain-locked to buildbrava.com) --------
# Set AUTH_DISABLED=true for local dev to bypass sign-in entirely.
# Leave unset/false in real deployments (auth then fails CLOSED if unconfigured).
AUTH_DISABLED=true
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
